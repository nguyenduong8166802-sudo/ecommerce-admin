<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/public/css/style.css" />
  <style>
    .container{max-width:1000px;margin:30px auto;padding:0 16px}
    .card{background:#fff;border-radius:16px;padding:20px;box-shadow:0 8px 24px rgba(0,0,0,.06)}
    .grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .field{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
    input,textarea{padding:12px;border:1px solid #ddd;border-radius:10px;font:inherit}
    textarea{min-height:110px;resize:vertical}
    .actions{display:flex;gap:12px;align-items:center}
    .ok{color:#1a7f37;font-weight:600}
    @media (max-width: 768px){.grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>Marketing</h1>
      <% if (success) { %><p class="ok">Đã lưu nội dung marketing.</p><% } %>
      <form method="post" action="/admin/marketing">
        <div class="field">
          <label>Banner đầu trang</label>
          <input name="top_banner" value="<%= marketing?.top_banner || '' %>" />
        </div>

        <div class="grid">
          <div class="field">
            <label>Badge</label>
            <input name="hero_badge" value="<%= marketing?.hero_badge || '' %>" />
          </div>
          <div class="field">
            <label>Tiêu đề lớn</label>
            <input name="hero_title" value="<%= marketing?.hero_title || '' %>" />
          </div>
        </div>

        <div class="field">
          <label>Mô tả ngắn</label>
          <textarea name="hero_description"><%= marketing?.hero_description || '' %></textarea>
        </div>

        <div class="grid">
          <div class="field">
            <label>CTA 1 text</label>
            <input name="cta_primary_text" value="<%= marketing?.cta_primary_text || '' %>" />
          </div>
          <div class="field">
            <label>CTA 1 URL</label>
            <input name="cta_primary_url" value="<%= marketing?.cta_primary_url || '' %>" />
          </div>
          <div class="field">
            <label>CTA 2 text</label>
            <input name="cta_secondary_text" value="<%= marketing?.cta_secondary_text || '' %>" />
          </div>
          <div class="field">
            <label>CTA 2 URL</label>
            <input name="cta_secondary_url" value="<%= marketing?.cta_secondary_url || '' %>" />
          </div>
        </div>

        <div class="actions">
          <button type="submit">Lưu Marketing</button>
          <a href="/admin">Quay lại admin</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
