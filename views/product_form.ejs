<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>DUONG MART PRO</title><link rel="stylesheet" href="/public/css/style.css"></head><body>
<div class="nav"><div class="nav-inner"><div><a class="brand" href="/">DUONG MART PRO</a></div>
<div class="links">
<a href="/">Trang chủ</a>
<% if (!currentUser) { %><a href="/login">Đăng nhập</a><a href="/register">Đăng ký</a><% } %>
<% if (currentUser && currentUser.role==='seller') { %><a href="/seller/products">Seller</a><% } %>
<% if (currentUser && currentUser.role==='admin') { %><a href="/admin">Admin</a><a href="/admin/products">Quản lý sản phẩm</a><% } %>
<% if (currentUser) { %><form action="/logout" method="post" style="display:inline"><button class="btn" style="padding:8px 12px">Đăng xuất</button></form><% } %>
</div></div></div>
<div class="container">

<div class="card" style="max-width:700px;margin:0 auto">
<h1><%= title %></h1>
<form method="post" action="<%= action %>">
  <% if (isAdmin) { %>
    <label>Seller sở hữu</label>
    <select name="seller_id">
      <option value="">-- Chưa gán --</option>
      <% sellers.forEach(s => { %>
        <option value="<%= s.id %>" <%= product && String(product.seller_id)===String(s.id) ? 'selected' : '' %>>
          <%= s.name %> - <%= s.email %>
        </option>
      <% }) %>
    </select>
  <% } %>
  <label>Tên sản phẩm</label><input name="name" value="<%= product ? product.name : '' %>" required>
  <label>Mô tả</label><textarea name="description"><%= product ? product.description : '' %></textarea>
  <label>Link ảnh</label><input name="image_url" value="<%= product ? (product.image_url || '') : '' %>">
  <label>Giá</label><input name="price" type="number" step="0.01" value="<%= product ? product.price : '' %>" required>
  <label>Tồn kho</label><input name="stock" type="number" value="<%= product ? product.stock : 0 %>" required>
  <label><input name="is_active" type="checkbox" <%= !product || product.is_active ? 'checked' : '' %>> Hiển thị sản phẩm</label>
  <div class="row" style="margin-top:16px">
    <button class="btn">Lưu</button>
    <a class="btn secondary" href="<%= isAdmin ? '/admin/products' : '/seller/products' %>">Quay lại</a>
  </div>
</form>
</div>
</div></body></html>