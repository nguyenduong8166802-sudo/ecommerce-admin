<%- include('partials/header', { title: product ? 'Sửa sản phẩm' : 'Thêm sản phẩm' }) %><div class="container section"><h1 class="page-title"><%= product ? 'Sửa sản phẩm' : 'Thêm sản phẩm mới' %></h1><div class="card"><form method="<%= method %>" action="<%= action %>"><div class="form-grid"><div><label>Tên sản phẩm</label><input name="name" value="<%= product?.name || '' %>" required></div><div><label>Giá bán</label><input type="number" name="price" value="<%= product?.price || '' %>" required></div></div><div class="form-grid mt-16"><div><label>Danh mục</label><select name="category_id"><option value="">Chọn danh mục</option><% categories.forEach(c => { %><option value="<%= c.id %>" <%= product && Number(product.category_id) === c.id ? 'selected' : '' %>><%= c.name %></option><% }) %></select></div><div><label>Tồn kho</label><input type="number" name="stock" value="<%= product?.stock ?? 0 %>"></div></div><label class="mt-16">Link ảnh</label><input name="image_url" value="<%= product?.image_url || '' %>" placeholder="https://i.ibb.co/..."><label class="mt-16">Mô tả</label><textarea name="description"><%= product?.description || '' %></textarea><% if (product) { %><label class="mt-16"><input style="width:auto" type="checkbox" name="is_active" <%= product.is_active ? 'checked' : '' %>> Hiển thị sản phẩm</label><% } %><button class="btn mt-24" type="submit"><%= product ? 'Lưu thay đổi' : 'Tạo sản phẩm' %></button></form></div></div><%- include('partials/footer') %>
