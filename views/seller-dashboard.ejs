<%- include('partials/header', { title: 'Seller Dashboard' }) %><div class="container section"><div class="flex-between"><h1 class="page-title">Seller Dashboard</h1><div class="stack"><a class="btn" href="/seller/products/new">+ Thêm sản phẩm</a><a class="btn secondary" href="/seller/orders">Đơn của seller</a></div></div><div class="kpi"><div class="card"><div class="small">Sản phẩm</div><strong><%= stats.products %></strong></div><div class="card"><div class="small">Đơn liên quan</div><strong><%= stats.orders %></strong></div><div class="card"><div class="small">Doanh số gộp</div><strong><%= currency(stats.gross) %></strong></div><div class="card"><div class="small">Hoa hồng sàn thu</div><strong><%= currency(stats.commission) %></strong></div></div><div class="card mt-24"><h3>Sản phẩm của tôi</h3><table class="table"><thead><tr><th>Sản phẩm</th><th>Giá</th><th>Tồn kho</th><th>Hiển thị</th><th></th></tr></thead><tbody><% products.forEach(p => { %><tr><td><strong><%= p.name %></strong></td><td><%= currency(p.price) %></td><td><%= p.stock %></td><td><%= p.is_active ? 'Bật' : 'Tắt' %></td><td><div class="stack"><a class="btn secondary" href="/seller/products/<%= p.id %>/edit">Sửa</a><form method="POST" action="/seller/products/<%= p.id %>?_method=DELETE"><button class="btn danger" type="submit">Xóa</button></form></div></td></tr><% }) %></tbody></table></div></div><%- include('partials/footer') %>
