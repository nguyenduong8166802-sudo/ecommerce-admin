<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: 'Marketing' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="toolbar"><h1 class="section-title">Marketing editable</h1><a class="btn-outline" href="/admin">Quay lại</a></div><div class="card"><form method="post" action="/admin/marketing"><div class="form-grid"><div class="form-group full"><label>Banner đầu trang</label><input name="top_banner" value="<%= marketing?.top_banner || '' %>" /></div><div class="form-group"><label>Badge</label><input name="hero_badge" value="<%= marketing?.hero_badge || '' %>" /></div><div class="form-group"><label>Tiêu đề lớn</label><input name="hero_title" value="<%= marketing?.hero_title || '' %>" /></div><div class="form-group full"><label>Mô tả</label><textarea name="hero_description"><%= marketing?.hero_description || '' %></textarea></div><div class="form-group"><label>CTA 1 text</label><input name="cta1_text" value="<%= marketing?.cta1_text || '' %>" /></div><div class="form-group"><label>CTA 1 link</label><input name="cta1_link" value="<%= marketing?.cta1_link || '' %>" /></div><div class="form-group"><label>CTA 2 text</label><input name="cta2_text" value="<%= marketing?.cta2_text || '' %>" /></div><div class="form-group"><label>CTA 2 link</label><input name="cta2_link" value="<%= marketing?.cta2_link || '' %>" /></div><div class="form-group"><label>Điểm nổi bật 1</label><input name="highlight_1" value="<%= marketing?.highlight_1 || '' %>" /></div><div class="form-group"><label>Điểm nổi bật 2</label><input name="highlight_2" value="<%= marketing?.highlight_2 || '' %>" /></div><div class="form-group"><label>Điểm nổi bật 3</label><input name="highlight_3" value="<%= marketing?.highlight_3 || '' %>" /></div><div class="form-group"><label>Điểm nổi bật 4</label><input name="highlight_4" value="<%= marketing?.highlight_4 || '' %>" /></div></div><div style="margin-top:16px;"><button class="btn" type="submit">Lưu marketing</button></div></form></div></div></body></html>
