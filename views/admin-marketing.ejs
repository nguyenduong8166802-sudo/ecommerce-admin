<%- include('partials/header', { title: 'Marketing' }) %><div class="container section"><h1 class="page-title">Marketing Message</h1><div class="card"><form method="POST" action="/admin/marketing"><label>Thông báo đầu trang</label><textarea name="top_banner_text"><%= marketing.top_banner_text %></textarea><label class="mt-16">Hero Title</label><input name="hero_title" value="<%= marketing.hero_title %>"><label class="mt-16">Hero Subtitle</label><textarea name="hero_subtitle"><%= marketing.hero_subtitle %></textarea><label class="mt-16">Nút CTA</label><input name="hero_cta_text" value="<%= marketing.hero_cta_text %>"><label class="mt-16">Popup Text</label><textarea name="popup_text"><%= marketing.popup_text %></textarea><label class="mt-16"><input type="checkbox" name="popup_enabled" <%= marketing.popup_enabled ? 'checked' : '' %> style="width:auto"> Bật popup</label><button class="btn mt-24" type="submit">Lưu Marketing</button></form></div></div><%- include('partials/footer') %>
