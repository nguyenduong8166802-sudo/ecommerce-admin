<%- include('partials-header', { marketing: { topBar: 'Quản lý marketing' } }) %>
<div class="auth-box wide">
  <h1>Marketing</h1>
  <form method="post" action="/admin/marketing">
    <label>Thanh thông báo</label><input name="topBar" value="<%= marketing.topBar %>" />
    <label>Tiêu đề banner</label><input name="heroTitle" value="<%= marketing.heroTitle %>" />
    <label>Mô tả banner</label><textarea name="heroText"><%= marketing.heroText %></textarea>
    <label>Nút CTA</label><input name="ctaText" value="<%= marketing.ctaText %>" />
    <button class="btn" type="submit">Lưu nội dung</button>
  </form>
</div>
<%- include('partials-footer') %>
