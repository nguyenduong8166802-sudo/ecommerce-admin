<%- include('partials-header', { marketing: { topBar: 'Seller Dashboard' } }) %>
<div class="dashboard-head">
  <h1>Seller Dashboard</h1>
  <a class="btn" href="/seller/products/new">+ Thêm sản phẩm</a>
</div>
<div class="stats">
  <div class="stat"><strong>Ví hiện tại</strong><span><%= user.wallet.toLocaleString('vi-VN') %>đ</span></div>
  <div class="stat"><strong>% affiliate F1</strong><span><%= affiliateSettings.f1 %>%</span></div>
  <div class="stat"><strong>Link affiliate</strong><span class="small"><%= referralLink %></span></div>
</div>
<section class="panel">
  <h3>Yêu cầu rút tiền</h3>
  <form method="post" action="/seller/withdraw" class="inline-form gap">
    <input type="number" name="amount" placeholder="Số tiền cần rút" />
    <button class="btn" type="submit">Gửi yêu cầu</button>
  </form>
</section>
<h2>Sản phẩm của bạn</h2>
<section class="grid">
  <% sellerProducts.forEach(p => { %><article class="card mini"><img src="<%= p.image %>" alt=""><h3><%= p.name %></h3><div class="price"><%= p.price.toLocaleString('vi-VN') %>đ</div></article><% }) %>
</section>
<h2>Lịch sử rút tiền</h2>
<table class="table"><tr><th>ID</th><th>Số tiền</th><th>Trạng thái</th></tr><% withdrawals.forEach(w => { %><tr><td><%= w.id %></td><td><%= w.amount.toLocaleString('vi-VN') %>đ</td><td><%= w.status %></td></tr><% }) %></table>
<%- include('partials-footer') %>
