<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: product ? 'Sửa sản phẩm' : 'Thêm sản phẩm' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="toolbar"><h1 class="section-title"><%= product ? 'Sửa sản phẩm' : 'Thêm sản phẩm' %></h1><a class="btn-outline" href="/admin/products">Quay lại</a></div><div class="card"><form method="post" action="<%= action %>"><div class="form-grid"><div class="form-group"><label>Seller</label><select name="seller_id"><option value="">-- Chọn seller --</option><% sellers.forEach(s=>{ %><option value="<%= s.id %>" <%= product && String(product.seller_id)===String(s.id)?'selected':'' %>><%= s.seller_name || s.email %></option><% }) %></select></div><div class="form-group"><label>Tên sản phẩm</label><input name="name" value="<%= product?.name || '' %>" required /></div><div class="form-group full"><label>Mô tả</label><textarea name="description"><%= product?.description || '' %></textarea></div><div class="form-group"><label>Giá</label><input name="price" type="number" step="0.01" value="<%= product?.price || 0 %>" /></div><div class="form-group"><label>Giá sale</label><input name="sale_price" type="number" step="0.01" value="<%= product?.sale_price || '' %>" /></div><div class="form-group"><label>Tồn kho</label><input name="stock" type="number" value="<%= product?.stock || 0 %>" /></div><div class="form-group"><label>Link ảnh</label><input name="image_url" value="<%= product?.image_url || '' %>" /></div><div class="form-group"><label><input type="checkbox" name="is_visible" <%= !product || product?.is_visible ? 'checked' : '' %> /> Hiển thị</label><label><input type="checkbox" name="is_featured" <%= product?.is_featured ? 'checked' : '' %> /> Nổi bật</label></div></div><div style="margin-top:16px;"><button class="btn" type="submit">Lưu sản phẩm</button></div></form></div></div></body></html>
