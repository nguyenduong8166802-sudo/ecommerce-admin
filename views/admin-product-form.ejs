
<%- include('partials/header') %>
<section class="auth-box">
  <h1><%= title %></h1>
  <form method="POST" action="<%= action %>" class="form-grid">
    <label>Seller
      <select name="seller_id">
        <option value="">-- Chưa gán --</option>
        <% sellers.forEach(s => { %>
          <option value="<%= s.id %>" <%= product && String(product.seller_id||'')===String(s.id) ? 'selected' : '' %>>
            <%= s.name %> - <%= s.email %>
          </option>
        <% }) %>
      </select>
    </label>
    <label>Tên sản phẩm<input type="text" name="name" value="<%= product ? product.name : '' %>" required></label>
    <label>Giá<input type="number" step="0.01" name="price" value="<%= product ? product.price : 0 %>" required></label>
    <label>Tồn kho<input type="number" name="stock" value="<%= product ? product.stock : 0 %>" required></label>
    <label>Link ảnh<input type="text" name="image_url" value="<%= product ? (product.image_url || '') : '' %>"></label>
    <label>Mô tả<textarea name="description" rows="5"><%= product ? (product.description || '') : '' %></textarea></label>
    <label class="checkbox-line"><input type="checkbox" name="is_active" <%= !product || product.is_active ? 'checked' : '' %> > Hiển thị sản phẩm</label>
    <button class="btn primary" type="submit">Lưu sản phẩm</button>
  </form>
</section>
<%- include('partials/footer') %>
