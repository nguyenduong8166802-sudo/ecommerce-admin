<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= storeSettings.siteName %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials-nav') %>
  <div class="container">
    <div class="hero">
      <h1><%= storeSettings.siteName %></h1>
      <p>Sàn thương mại điện tử đơn giản có quản lý sản phẩm, người bán, đơn hàng và chính sách hoa hồng.</p>
    </div>

    <div class="grid">
      <% products.forEach(product => { %>
        <div class="card">
          <h3><%= product.name %></h3>
          <p>Người bán: <strong><%= product.seller?.name || 'N/A' %></strong></p>
          <p>Giá: <strong><%= formatMoney(product.price) %></strong></p>
          <p>Tồn kho: <%= product.stock %></p>
          <form action="/checkout" method="POST">
            <input type="hidden" name="productId" value="<%= product.id %>">
            <label>Tên khách hàng</label>
            <input type="text" name="customerName" placeholder="Nhập tên khách">
            <label>Số lượng</label>
            <input type="number" name="qty" min="1" value="1">
            <button class="btn" type="submit">Mua ngay</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
