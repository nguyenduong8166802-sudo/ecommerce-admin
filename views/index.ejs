<%- include('partials/header', { title: 'DUONG MART PRO' }) %><div class="announce"><div class="container"><%= marketing.top_banner_text %></div></div><section class="container hero"><div class="card"><span class="badge">PRO Marketplace</span><h1><%= marketing.hero_title %></h1><p><%= marketing.hero_subtitle %></p><div class="stack"><a class="btn" href="/products"><%= marketing.hero_cta_text %></a><a class="btn secondary" href="/login">Đăng nhập admin/seller</a></div></div><div class="card"><h3>Khung tính năng có sẵn</h3><ul class="list-reset"><li>Admin dashboard</li><li>Seller dashboard</li><li>Quản lý sản phẩm</li><li>Giỏ hàng & checkout</li><li>Tự tính commission</li><li>Marketing message</li><li>Flash Sale</li></ul></div></section><section class="container section"><h2>Danh mục nổi bật</h2><div class="grid"><% categories.forEach(cat => { %><div class="card center"><strong><%= cat.name %></strong></div><% }) %></div></section><% if (flashProducts.length) { %><section class="container section"><div class="flex-between"><h2>Flash Sale đang chạy</h2><span class="flash-tag">FLASH SALE</span></div><div class="grid"><% flashProducts.forEach(product => { %><div class="product-card"><a href="/products/<%= product.id %>"><img src="<%= product.image_url %>" alt="<%= product.name %>"></a><div class="product-info"><div class="flash-tag"><%= product.flash_sale_name %></div><div class="product-name mt-16"><%= product.name %></div><div class="price"><span class="current"><%= currency(product.sale_price) %></span><span class="old"><%= currency(product.price) %></span></div><form action="/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= product.id %>"><button class="btn" type="submit">Thêm vào giỏ</button></form></div></div><% }) %></div></section><% } %><section class="container section"><h2>Sản phẩm mới</h2><div class="grid"><% products.forEach(product => { %><div class="product-card"><a href="/products/<%= product.id %>"><img src="<%= product.image_url %>" alt="<%= product.name %>"></a><div class="product-info"><% if (product.sale_price) { %><div class="flash-tag">Giảm <%= product.sale_percent || '' %>%</div><% } %><div class="product-name mt-16"><%= product.name %></div><div class="small"><%= product.category_name || 'Chưa phân loại' %> • <%= product.seller_name %></div><div class="price"><span class="current"><%= currency(product.sale_price || product.price) %></span><% if (product.sale_price) { %><span class="old"><%= currency(product.price) %></span><% } %></div><form action="/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= product.id %>"><button class="btn" type="submit">Thêm vào giỏ</button></form></div></div><% }) %></div></section><%- include('partials/footer') %>
