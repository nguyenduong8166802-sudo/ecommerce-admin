<%- include('partials-header', { marketing }) %>
<section class="hero">
  <div>
    <h1><%= marketing.heroTitle %></h1>
    <p><%= marketing.heroText %></p>
    <div class="cta-row">
      <a class="btn" href="/login">Mua ngay</a>
      <a class="btn btn-outline" href="/login"><%= marketing.ctaText %></a>
    </div>
  </div>
  <div class="panel">
    <h3>Vì sao chọn DUONG MART PRO?</h3>
    <ul>
      <li>✔ Sản phẩm thật, giá rõ ràng</li>
      <li>✔ Seller có ví và rút tiền</li>
      <li>✔ Có flash sale và banner marketing</li>
      <li>✔ Phù hợp bán hàng và tuyển CTV</li>
    </ul>
  </div>
</section>
<h2>Flash Sale hôm nay</h2>
<section class="grid">
  <% products.forEach(p => { %>
    <article class="card">
      <img src="<%= p.image %>" alt="<%= p.name %>" />
      <h3><%= p.name %></h3>
      <p><%= p.description %></p>
      <div class="price"><%= p.price.toLocaleString('vi-VN') %>đ <% if (p.oldPrice) { %><span><%= p.oldPrice.toLocaleString('vi-VN') %>đ</span><% } %></div>
      <% if (p.flashSale) { %><div class="badge">FLASH SALE</div><% } %>
    </article>
  <% }) %>
</section>
<%- include('partials-footer') %>
