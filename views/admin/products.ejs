<%- include('../partials/header') %>
<section class="section">
  <div class="container admin-grid">
    <div>
      <h1>Quản lý sản phẩm</h1>
      <table class="table">
        <tr><th>Tên</th><th>Seller</th><th>Giá</th><th>Tồn</th><th></th></tr>
        <% products.forEach(product => { %>
          <tr>
            <td><%= product.name %></td>
            <td><%= product.sellerName %></td>
            <td><%= currency(product.finalPrice) %></td>
            <td><%= product.stock %></td>
            <td>
              <a class="btn btn-sm" href="/admin/products/<%= product.id %>/edit">Sửa</a>
              <form action="/admin/products/<%= product.id %>/delete" method="post" class="inline">
                <button class="btn btn-danger btn-sm">Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>
    <div>
      <form action="/admin/products/save" method="post" class="form-card sticky">
        <h2><%= editProduct ? 'Sửa sản phẩm' : 'Thêm sản phẩm mới' %></h2>
        <input type="hidden" name="id" value="<%= editProduct?.id || '' %>" />
        <label>Seller
          <select name="sellerId" required>
            <% sellers.forEach(s => { %>
              <option value="<%= s.id %>" <%= editProduct?.sellerId === s.id ? 'selected' : '' %>><%= s.fullName %></option>
            <% }) %>
          </select>
        </label>
        <label>Danh mục
          <select name="categoryId" required>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>" <%= editProduct?.categoryId === c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Tên sản phẩm<input type="text" name="name" value="<%= editProduct?.name || '' %>" required /></label>
        <label>Giá gốc<input type="number" name="price" value="<%= editProduct?.price || '' %>" required /></label>
        <label>Giá bán<input type="number" name="salePrice" value="<%= editProduct?.salePrice || '' %>" /></label>
        <label>Tồn kho<input type="number" name="stock" value="<%= editProduct?.stock || '' %>" required /></label>
        <label>Link ảnh<input type="text" name="imageUrl" value="<%= editProduct?.imageUrl || '' %>" required /></label>
        <label>Mô tả ngắn<textarea name="shortDesc"><%= editProduct?.shortDesc || '' %></textarea></label>
        <label>Mô tả chi tiết<textarea name="description"><%= editProduct?.description || '' %></textarea></label>
        <label class="checkbox"><input type="checkbox" name="featured" <%= editProduct?.featured ? 'checked' : '' %> /> Đưa lên nổi bật</label>
        <button class="btn">Lưu sản phẩm</button>
      </form>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
