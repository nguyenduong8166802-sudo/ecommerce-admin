<%- include('../partials/header') %>
<section class="section">
  <div class="container">
    <div class="dash-head between center">
      <h1>Admin Dashboard</h1>
      <div class="tabs"><a href="/admin/products">Sản phẩm</a><a href="/admin/orders">Đơn hàng</a><a href="/admin/sellers">Seller</a></div>
    </div>
    <div class="stats-grid">
      <div class="stat-card"><span>Sản phẩm</span><strong><%= stats.products %></strong></div>
      <div class="stat-card"><span>Seller</span><strong><%= stats.sellers %></strong></div>
      <div class="stat-card"><span>Đơn hàng</span><strong><%= stats.orders %></strong></div>
      <div class="stat-card"><span>Doanh thu</span><strong><%= currency(stats.totalRevenue) %></strong></div>
      <div class="stat-card"><span>Hoa hồng sàn</span><strong><%= currency(stats.totalCommission) %></strong></div>
      <div class="stat-card"><span>Seller thực nhận</span><strong><%= currency(stats.totalSellerPayout) %></strong></div>
    </div>
    <h2 class="top-gap">Đơn hàng gần đây</h2>
    <table class="table">
      <tr><th>Mã đơn</th><th>Khách</th><th>Trạng thái</th><th>Tổng</th></tr>
      <% recentOrders.forEach(order => { %>
        <tr><td><%= order.code %></td><td><%= order.customer.fullName %></td><td><%= order.status %></td><td><%= currency(order.totals.total) %></td></tr>
      <% }) %>
    </table>
  </div>
</section>
<%- include('../partials/footer') %>
