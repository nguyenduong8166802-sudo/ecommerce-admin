<%- include('../partials/header') %>
<section class="section">
  <div class="container">
    <h1>Quản lý seller & hoa hồng</h1>
    <table class="table">
      <tr><th>Seller</th><th>Email</th><th>% hoa hồng</th><th>Gross</th><th>Hoa hồng sàn</th><th>Seller thực nhận</th></tr>
      <% sellers.forEach(seller => { %>
        <tr>
          <td><%= seller.fullName %></td>
          <td><%= seller.email %></td>
          <td><%= seller.commissionRate %>%</td>
          <td><%= currency(seller.gross) %></td>
          <td><%= currency(seller.commission) %></td>
          <td><%= currency(seller.receivable) %></td>
        </tr>
      <% }) %>
    </table>
  </div>
</section>
<%- include('../partials/footer') %>
