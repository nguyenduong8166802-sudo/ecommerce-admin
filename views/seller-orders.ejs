<%- include('partials/header', { title: 'Đơn của Seller' }) %><div class="container section"><h1 class="page-title">Đơn hàng của seller</h1><table class="table"><thead><tr><th>Mã đơn</th><th>Sản phẩm</th><th>SL</th><th>Doanh thu</th><th>% HH</th><th>Tiền HH</th><th>Khách</th><th>Ngày</th></tr></thead><tbody><% items.forEach(i => { %><tr><td>#<%= i.order_id %></td><td><%= i.product_name %></td><td><%= i.qty %></td><td><%= currency(i.line_total) %></td><td><%= i.commission_rate %>%</td><td><%= currency(i.commission_amount) %></td><td><%= i.full_name %><div class="small"><%= i.phone || '' %></div></td><td><%= new Date(i.created_at).toLocaleString('vi-VN') %></td></tr><% }) %></tbody></table></div><%- include('partials/footer') %>
