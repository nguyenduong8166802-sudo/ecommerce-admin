
<%- include('partials-header', { title: 'Đăng nhập', currentUser }) %>
<div class="login-card card">
  <h2>Đăng nhập hệ thống</h2>
  <p class="muted">Admin: admin@duongmart.vn / admin123<br>Seller: seller1@duongmart.vn / seller123</p>
  <% if (error) { %><p style="color:#dc2626"><%= error %></p><% } %>
  <form method="POST" action="/login">
    <label>Email</label>
    <input type="email" name="email" required />
    <label>Mật khẩu</label>
    <input type="password" name="password" required />
    <div style="margin-top:16px"><button class="btn">Đăng nhập</button></div>
  </form>
</div>
<%- include('partials-footer') %>
