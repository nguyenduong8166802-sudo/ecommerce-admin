<%- include('partials-header', { marketing: { topBar: 'Đăng nhập hệ thống DUONG MART PRO' } }) %>
<div class="auth-box">
  <h1>Đăng nhập</h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form method="post" action="/login">
    <label>Email</label><input name="email" />
    <label>Mật khẩu</label><input name="password" type="password" />
    <button class="btn" type="submit">Đăng nhập</button>
  </form>
  <p class="hint">Admin: admin@duongmart.vn / admin123<br>Seller: seller1@duongmart.vn / seller123<br>Buyer: buyer1@duongmart.vn / buyer123</p>
</div>
<%- include('partials-footer') %>
