<%- include('partials/header', { title: 'Checkout' }) %><div class="container section"><h1 class="page-title">Thanh toán</h1><% if (error) { %><div class="alert"><%= error %></div><% } %><div class="card"><form method="POST" action="/checkout"><div class="form-grid"><div><label>Họ tên</label><input name="full_name" required></div><div><label>Số điện thoại</label><input name="phone"></div></div><label class="mt-16">Địa chỉ</label><textarea name="address" required></textarea><label class="mt-16">Ghi chú</label><textarea name="note"></textarea><div class="mt-24"><strong>Tổng thanh toán: <%= currency(total) %></strong></div><button class="btn mt-24" type="submit">Tạo đơn hàng</button></form></div></div><%- include('partials/footer') %>
