<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: 'Admin Products' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="toolbar"><h1 class="section-title">Quản lý sản phẩm</h1><a class="btn" href="/admin/products/new">+ Thêm sản phẩm</a></div><table class="table"><thead><tr><th>ID</th><th>Sản phẩm</th><th>Seller</th><th>Giá</th><th>Sale</th><th>Tồn</th><th>Hiển thị</th><th></th></tr></thead><tbody><% products.forEach(p=>{ %><tr><td><%= p.id %></td><td><div class="product-inline"><img src="<%= p.image_url || 'https://via.placeholder.com/100' %>" /><div><div style="font-weight:700"><%= p.name %></div><div class="small muted"><%= p.description || '' %></div></div></div></td><td><%= p.seller_name || '-' %></td><td><%= formatMoney(p.price) %></td><td><%= p.sale_price ? formatMoney(p.sale_price) : '-' %></td><td><%= p.stock %></td><td><%= p.is_visible ? 'Bật' : 'Tắt' %></td><td class="right"><a class="btn-outline" href="/admin/products/<%= p.id %>/edit">Sửa</a><form method="post" action="/admin/products/<%= p.id %>/delete" style="display:inline-block;margin-left:8px;"><button class="btn-danger" type="submit">Xóa</button></form></td></tr><% }) %></tbody></table></div></body></html>
