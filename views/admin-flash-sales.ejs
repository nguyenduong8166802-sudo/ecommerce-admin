<%- include('partials/header', { title: 'Flash Sale' }) %><div class="container section"><h1 class="page-title">Flash Sale</h1><div class="card"><h3>Tạo chương trình mới</h3><form method="POST" action="/admin/flash-sales"><div class="form-grid"><div><label>Tên chương trình</label><input name="name" required></div><div><label>% giảm</label><input name="sale_percent" type="number" step="0.01" value="10"></div></div><label class="mt-16">Mô tả</label><textarea name="description"></textarea><div class="form-grid mt-16"><div><label>Bắt đầu</label><input type="datetime-local" name="start_at" required></div><div><label>Kết thúc</label><input type="datetime-local" name="end_at" required></div></div><label class="mt-16">Chọn sản phẩm</label><select name="product_ids" multiple size="8"><% products.forEach(p => { %><option value="<%= p.id %>"><%= p.name %> - <%= currency(p.price) %></option><% }) %></select><div class="small mt-16">Giữ Ctrl để chọn nhiều sản phẩm.</div><button class="btn mt-24" type="submit">Tạo Flash Sale</button></form></div><div class="card mt-24"><h3>Danh sách chương trình</h3><table class="table"><thead><tr><th>Tên</th><th>Thời gian</th><th>Items</th><th>Trạng thái</th><th></th></tr></thead><tbody><% flashSales.forEach(fs => { %><tr><td><strong><%= fs.name %></strong><div class="small"><%= fs.description || '' %></div></td><td><%= new Date(fs.start_at).toLocaleString('vi-VN') %><br>→ <%= new Date(fs.end_at).toLocaleString('vi-VN') %></td><td><%= fs.item_count %></td><td><%= fs.is_active ? 'Đang bật' : 'Đang tắt' %></td><td><form method="POST" action="/admin/flash-sales/<%= fs.id %>/toggle"><button class="btn secondary" type="submit"><%= fs.is_active ? 'Tắt' : 'Bật' %></button></form></td></tr><% }) %></tbody></table></div></div><%- include('partials/footer') %>
