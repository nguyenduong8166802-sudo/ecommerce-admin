<%- include('partials/header') %>
<section class="section">
  <div class="container narrow">
    <div class="success-box">
      <h1>Đặt hàng thành công</h1>
      <p>Mã đơn: <strong><%= order.code %></strong></p>
      <p>Khách hàng: <%= order.customer.fullName %> - <%= order.customer.phone %></p>
      <p>Tổng tiền: <strong><%= currency(order.totals.total) %></strong></p>
      <p>Tổng hoa hồng sàn: <strong><%= currency(order.totals.commissionTotal) %></strong></p>
      <a class="btn" href="/shop">Tiếp tục mua hàng</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
