<%- include('partials/header') %>
<section class="section product-detail">
  <div class="detail-grid">
    <div class="card"><img class="detail-image" src="<%= product.image_url || 'https://via.placeholder.com/600x420?text=No+Image' %>" alt="<%= product.name %>"></div>
    <div class="card">
      <h1><%= product.name %></h1>
      <p class="muted">Seller: <%= product.seller_name || 'Seller' %> • Danh mục: <%= product.category_name || 'Danh mục' %></p>
      <div class="price-row big"><strong><%= currency(product.flash ? product.flash.sale_price : product.price) %></strong><% if (product.flash) { %><span class="old-price"><%= currency(product.price) %></span><span class="badge">Flash Sale</span><% } %></div>
      <p><%= product.description %></p>
      <form action="/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= product.id %>"><button class="btn primary">Mua ngay</button></form>
    </div>
  </div>
</section>
<%- include('partials/footer') %>