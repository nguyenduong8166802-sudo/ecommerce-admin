<%- include('partials-header', { marketing: { topBar: 'Cấu hình affiliate' } }) %>
<div class="auth-box wide">
  <h1>Affiliate Settings</h1>
  <form method="post" action="/admin/affiliate">
    <label>F1 (%)</label><input name="f1" type="number" value="<%= affiliateSettings.f1 %>" />
    <label>Phí sàn (%)</label><input name="platformFee" type="number" value="<%= affiliateSettings.platformFee %>" />
    <label>Rút tối thiểu</label><input name="minWithdraw" type="number" value="<%= affiliateSettings.minWithdraw %>" />
    <button class="btn" type="submit">Lưu cấu hình</button>
  </form>
</div>
<%- include('partials-footer') %>
