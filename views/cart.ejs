
<%- include('partials/header') %>
<section class="panel-header">
  <h1>Giỏ hàng</h1>
</section>
<% if (!cart.length) { %>
  <p>Giỏ hàng đang trống.</p>
<% } else { %>
  <table class="table">
    <thead><tr><th>Sản phẩm</th><th>Giá</th><th>SL</th><th>Thành tiền</th></tr></thead>
    <tbody>
      <% let total = 0; cart.forEach(item => { total += item.price * item.qty; %>
      <tr>
        <td><%= item.name %></td>
        <td><%= Number(item.price).toLocaleString('vi-VN') %> đ</td>
        <td><%= item.qty %></td>
        <td><%= Number(item.price * item.qty).toLocaleString('vi-VN') %> đ</td>
      </tr>
      <% }) %>
      <tr>
        <td colspan="3"><strong>Tổng</strong></td>
        <td><strong><%= Number(total).toLocaleString('vi-VN') %> đ</strong></td>
      </tr>
    </tbody>
  </table>
  <% if (currentUser) { %>
    <form action="/checkout" method="POST">
      <button class="btn primary" type="submit">Đặt hàng</button>
    </form>
  <% } else { %>
    <p>Vui lòng <a href="/login">đăng nhập</a> để đặt hàng.</p>
  <% } %>
<% } %>
<%- include('partials/footer') %>
