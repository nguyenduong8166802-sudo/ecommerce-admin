<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: 'Giỏ hàng' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="toolbar"><h1 class="section-title">Giỏ hàng</h1></div><% if (!items.length) { %><div class="card">Chưa có sản phẩm trong giỏ.</div><% } else { %><table class="table"><thead><tr><th>Sản phẩm</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead><tbody><% let total = 0; items.forEach(item=>{ total += item.lineTotal; %><tr><td><div class="product-inline"><img src="<%= item.image_url || 'https://via.placeholder.com/100' %>" /><div><%= item.name %></div></div></td><td><%= item.qty %></td><td><%= formatMoney(item.sale_price || item.price) %></td><td><%= formatMoney(item.lineTotal) %></td></tr><% }) %></tbody></table><div class="toolbar"><div></div><div><div class="price">Tổng: <%= formatMoney(total) %></div><% if (currentUser) { %><form method="post" action="/checkout"><button class="btn" type="submit">Đặt hàng</button></form><% } else { %><a class="btn" href="/login">Đăng nhập để đặt hàng</a><% } %></div></div><% } %></div></body></html>
