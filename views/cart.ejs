<%- include('partials/header') %>
<section class="section">
  <div class="container narrow">
    <h1>Giỏ hàng</h1>
    <% if (!items.length) { %>
      <div class="empty-box">Chưa có sản phẩm trong giỏ. <a href="/shop">Đi mua sắm</a></div>
    <% } else { %>
      <table class="table">
        <tr><th>Sản phẩm</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th><th></th></tr>
        <% items.forEach(item => { %>
          <tr>
            <td><%= item.name %></td>
            <td>
              <form action="/cart/update" method="post" class="inline-flex">
                <input type="hidden" name="productId" value="<%= item.id %>" />
                <input type="number" name="qty" min="1" value="<%= item.qty %>" class="qty" />
                <button class="btn btn-sm">Cập nhật</button>
              </form>
            </td>
            <td><%= currency(item.finalPrice) %></td>
            <td><%= currency(item.lineTotal) %></td>
            <td>
              <form action="/cart/remove" method="post">
                <input type="hidden" name="productId" value="<%= item.id %>" />
                <button class="btn btn-danger btn-sm">Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
      <div class="summary-box">
        <h3>Tổng cộng: <%= currency(total) %></h3>
        <a class="btn" href="/checkout">Tiến hành thanh toán</a>
      </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
