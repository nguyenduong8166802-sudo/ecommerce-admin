<%- include('partials/header', { title: 'Giỏ hàng' }) %><div class="container section"><h1 class="page-title">Giỏ hàng</h1><% if (!cart.length) { %><div class="card">Giỏ hàng đang trống.</div><% } else { %><table class="table"><thead><tr><th>Sản phẩm</th><th>Giá</th><th>SL</th><th>Thành tiền</th><th></th></tr></thead><tbody><% cart.forEach(item => { %><tr><td><strong><%= item.name %></strong></td><td><%= currency(item.price) %></td><td><%= item.qty %></td><td><%= currency(item.price * item.qty) %></td><td><form action="/cart/remove" method="POST"><input type="hidden" name="product_id" value="<%= item.product_id %>"><button class="btn danger" type="submit">Xóa</button></form></td></tr><% }) %></tbody></table><div class="card mt-24"><div class="flex-between"><strong>Tổng cộng</strong><strong><%= currency(total) %></strong></div><div class="mt-24"><% if (currentUser) { %><a class="btn" href="/checkout">Tiến hành thanh toán</a><% } else { %><a class="btn" href="/login">Đăng nhập để thanh toán</a><% } %></div></div><% } %></div><%- include('partials/footer') %>
