<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: 'Flash Sale' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="toolbar"><h1 class="section-title">Flash Sale editable</h1><a class="btn-outline" href="/admin">Quay lại</a></div><div class="card"><form method="post" action="/admin/flashsale"><div class="form-grid"><div class="form-group"><label>Tiêu đề</label><input name="title" value="<%= flash?.title || '' %>" /></div><div class="form-group"><label><input type="checkbox" name="is_enabled" <%= flash?.is_enabled ? 'checked' : '' %> /> Bật flash sale</label></div><div class="form-group full"><label>Mô tả</label><textarea name="description"><%= flash?.description || '' %></textarea></div><div class="form-group"><label>Bắt đầu</label><input type="datetime-local" name="starts_at" value="<%= flash?.starts_at ? new Date(flash.starts_at).toISOString().slice(0,16) : '' %>" /></div><div class="form-group"><label>Kết thúc</label><input type="datetime-local" name="ends_at" value="<%= flash?.ends_at ? new Date(flash.ends_at).toISOString().slice(0,16) : '' %>" /></div></div><div style="margin-top:16px;"><button class="btn" type="submit">Lưu flash sale</button></div></form></div><div class="toolbar"><h2 style="font-size:30px">Giá sale từng sản phẩm</h2></div><table class="table"><thead><tr><th>Sản phẩm</th><th>Giá gốc</th><th>Giá sale</th><th></th></tr></thead><tbody><% products.forEach(p=>{ %><tr><td><%= p.name %></td><td><%= formatMoney(p.price) %></td><td><form method="post" action="/admin/flashsale/product/<%= p.id %>" style="display:flex;gap:10px;"><input name="sale_price" type="number" step="0.01" value="<%= p.sale_price || '' %>" /><button class="btn" type="submit">Lưu</button></form></td><td></td></tr><% }) %></tbody></table></div></body></html>
