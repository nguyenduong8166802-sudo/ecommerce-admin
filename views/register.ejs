<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: 'Đăng ký' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="auth-box card"><h1>Đăng ký tài khoản</h1><% if (message) { %><div class="notice"><%= message %></div><% } %><form method="post" action="/register"><div class="form-group"><label>Họ tên</label><input name="name" required /></div><div class="form-group"><label>Email</label><input name="email" type="email" required /></div><div class="form-group"><label>Mật khẩu</label><input name="password" type="password" required /></div><div class="form-group"><label>Loại tài khoản</label><select name="role" id="role" onchange="document.getElementById('sellerBox').style.display=this.value==='seller'?'block':'none'"><option value="buyer" <%= role==='buyer'?'selected':'' %>>Buyer</option><option value="seller" <%= role==='seller'?'selected':'' %>>Seller</option></select></div><div class="form-group" id="sellerBox" style="display:<%= role==='seller'?'block':'none' %>"><label>Tên gian hàng</label><input name="seller_name" /></div><div style="margin-top:16px;"><button class="btn" type="submit">Đăng ký</button></div></form></div></div></body></html>
