<%- include('partials/header', { title: 'Đăng ký' }) %><div class="container auth-wrap"><div class="card"><h1 class="page-title">Đăng ký tài khoản</h1><% if (error) { %><div class="alert"><%= error %></div><% } %><form method="POST" action="/register"><label>Họ tên</label><input name="name" required><label class="mt-16">Email</label><input name="email" type="email" required><label class="mt-16">Mật khẩu</label><input name="password" type="password" required><label class="mt-16">Vai trò</label><select name="role"><option value="buyer">Buyer</option><option value="seller">Seller</option></select><button class="btn mt-24" type="submit">Tạo tài khoản</button></form></div></div><%- include('partials/footer') %>
