<%- include('partials-header', { marketing: { topBar: 'Duyệt rút tiền' } }) %>
<h1>Yêu cầu rút tiền</h1>
<table class="table">
  <tr><th>ID</th><th>User</th><th>Số tiền</th><th>Trạng thái</th><th>Hành động</th></tr>
  <% withdrawalRows.forEach(w => { %>
    <tr>
      <td><%= w.id %></td>
      <td><%= w.user ? w.user.email : w.userId %></td>
      <td><%= w.amount.toLocaleString('vi-VN') %>đ</td>
      <td><%= w.status %></td>
      <td>
        <form method="post" action="/admin/withdrawals/<%= w.id %>/approved" class="inline-form"><button class="btn small-btn" type="submit">Duyệt</button></form>
        <form method="post" action="/admin/withdrawals/<%= w.id %>/rejected" class="inline-form"><button class="btn btn-outline small-btn" type="submit">Từ chối</button></form>
      </td>
    </tr>
  <% }) %>
</table>
<%- include('partials-footer') %>
