<%- include('partials/header', { title: 'Admin Dashboard' }) %><div class="container section"><div class="flex-between"><h1 class="page-title">Admin Dashboard</h1><div class="stack"><a class="btn secondary" href="/admin/sellers">Seller</a><a class="btn secondary" href="/admin/marketing">Marketing</a><a class="btn secondary" href="/admin/flash-sales">Flash Sale</a><a class="btn secondary" href="/admin/orders">Orders</a></div></div><div class="kpi"><div class="card"><div class="small">Người dùng</div><strong><%= stats.users %></strong></div><div class="card"><div class="small">Seller</div><strong><%= stats.sellers %></strong></div><div class="card"><div class="small">Sản phẩm</div><strong><%= stats.products %></strong></div><div class="card"><div class="small">Doanh thu</div><strong><%= currency(stats.revenue) %></strong></div></div><div class="card mt-24"><h3>Đơn mới nhất</h3><table class="table"><thead><tr><th>Mã đơn</th><th>Khách</th><th>Trạng thái</th><th>Tổng</th></tr></thead><tbody><% latestOrders.forEach(order => { %><tr><td>#<%= order.id %></td><td><%= order.full_name %></td><td><%= order.status %></td><td><%= currency(order.total_amount) %></td></tr><% }) %></tbody></table></div></div><%- include('partials/footer') %>
