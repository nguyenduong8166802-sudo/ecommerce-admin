<%- include('partials/header', { title: 'Đơn hàng của tôi' }) %><div class="container section"><h1 class="page-title">Đơn hàng của tôi</h1><table class="table"><thead><tr><th>Mã đơn</th><th>Khách</th><th>Địa chỉ</th><th>Trạng thái</th><th>Tổng</th><th>Ngày</th></tr></thead><tbody><% orders.forEach(order => { %><tr><td>#<%= order.id %></td><td><%= order.full_name %></td><td><%= order.address %></td><td><%= order.status %></td><td><%= currency(order.total_amount) %></td><td><%= new Date(order.created_at).toLocaleString('vi-VN') %></td></tr><% }) %></tbody></table></div><%- include('partials/footer') %>
