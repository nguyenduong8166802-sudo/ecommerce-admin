<!DOCTYPE html><html lang="vi"><head><%- include('partials-head', { title: 'Banner quảng cáo' }) %></head><body><%- include('partials-nav') %><div class="container"><div class="toolbar"><h1 class="section-title">Banner quảng cáo</h1><a class="btn-outline" href="/admin">Quay lại</a></div><div class="banner-grid"><% banners.forEach(b=>{ %><div class="card"><form method="post" action="/admin/banners/<%= b.slot %>"><div class="form-group"><label>Slot</label><input value="<%= b.slot %>" disabled /></div><div class="form-group"><label>Tiêu đề</label><input name="title" value="<%= b.title || '' %>" /></div><div class="form-group"><label>Link ảnh banner</label><input name="image_url" value="<%= b.image_url || '' %>" /></div><div class="form-group"><label>Link bấm vào</label><input name="link_url" value="<%= b.link_url || '' %>" /></div><div class="form-group"><label><input type="checkbox" name="is_enabled" <%= b.is_enabled ? 'checked' : '' %> /> Bật banner</label></div><% if (b.image_url) { %><img src="<%= b.image_url %>" alt="banner" style="height:170px;object-fit:cover;border-radius:12px;" /><% } %><div style="margin-top:12px;"><button class="btn" type="submit">Lưu banner</button></div></form></div><% }) %></div></div></body></html>
