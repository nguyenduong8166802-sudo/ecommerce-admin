<%- include('partials/header') %>
<section class="section">
  <div class="section-head"><h1>Tất cả sản phẩm</h1></div>
  <div class="product-grid">
    <% products.forEach(product => { %>
      <div class="product-card">
        <a href="/products/<%= product.slug %>"><img src="<%= product.image_url || 'https://via.placeholder.com/400x300?text=No+Image' %>" alt="<%= product.name %>"></a>
        <% if (product.flash) { %><span class="badge">-<%= Number(product.flash.sale_percent || 0).toFixed(0) %>%</span><% } %>
        <div class="content">
          <h3><a href="/products/<%= product.slug %>"><%= product.name %></a></h3>
          <p class="muted"><%= product.category_name || 'Danh mục' %> • <%= product.seller_name || 'Seller' %></p>
          <div class="price-row"><strong><%= currency(product.flash ? product.flash.sale_price : product.price) %></strong><% if (product.flash) { %><span class="old-price"><%= currency(product.price) %></span><% } %></div>
          <form action="/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= product.id %>"><button class="btn primary">Thêm vào giỏ</button></form>
        </div>
      </div>
    <% }) %>
  </div>
</section>
<%- include('partials/footer') %>