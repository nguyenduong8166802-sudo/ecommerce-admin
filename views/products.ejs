<%- include('partials/header', { title: 'Sản phẩm' }) %><div class="container section"><h1 class="page-title">Tất cả sản phẩm</h1><div class="grid"><% products.forEach(product => { %><div class="product-card"><a href="/products/<%= product.id %>"><img src="<%= product.image_url %>" alt="<%= product.name %>"></a><div class="product-info"><% if (product.sale_price) { %><div class="flash-tag"><%= product.flash_sale_name %></div><% } %><div class="product-name mt-16"><%= product.name %></div><div class="small"><%= product.category_name || 'Chưa phân loại' %></div><div class="price"><span class="current"><%= currency(product.sale_price || product.price) %></span><% if (product.sale_price) { %><span class="old"><%= currency(product.price) %></span><% } %></div><form action="/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= product.id %>"><button class="btn" type="submit">Thêm vào giỏ</button></form></div></div><% }) %></div></div><%- include('partials/footer') %>
