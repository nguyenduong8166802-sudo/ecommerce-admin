<%- include('partials/header', { title: 'Admin Seller' }) %><div class="container section"><h1 class="page-title">Quản lý Seller & % Hoa hồng</h1><table class="table"><thead><tr><th>Seller</th><th>Email</th><th>% Hoa hồng</th><th>Doanh số</th><th>Hoa hồng thu</th><th>Cập nhật</th></tr></thead><tbody><% sellers.forEach(s => { %><tr><td><strong><%= s.name %></strong></td><td><%= s.email %></td><td><%= s.commission_rate %>%</td><td><%= currency(s.gross_sales) %></td><td><%= currency(s.total_commission) %></td><td><form method="POST" action="/admin/sellers/<%= s.id %>/commission" class="stack"><input name="commission_rate" type="number" min="0" step="0.01" value="<%= s.commission_rate %>" style="max-width:130px"><button class="btn" type="submit">Lưu %</button></form></td></tr><% }) %></tbody></table></div><%- include('partials/footer') %>
