<%- include('partials/header') %>
<section class="section">
  <div class="section-head"><h1>Seller & Affiliate nhiều tầng</h1><a class="btn" href="/admin/affiliate">Cài đặt Affiliate</a></div>
  <table class="table">
    <tr><th>Seller</th><th>Ref code</th><th>Parent</th><th>Fí sàn %</th><th>F1 %</th><th>Ví</th><th>Cập nhật</th></tr>
    <% sellers.forEach(s => { %>
      <tr>
        <td><strong><%= s.name %></strong><br><span class="muted"><%= s.email %></span></td>
        <td><%= s.referral_code || '' %></td>
        <td><%= s.parent_name || '-' %></td>
        <td colspan="4">
          <form action="/admin/sellers/<%= s.id %>/commission" method="POST" class="inline-form wrap">
            <input name="commission_rate" type="number" step="0.01" value="<%= s.commission_rate %>">
            <input name="referral_rate" type="number" step="0.01" value="<%= s.referral_rate %>">
            <select name="parent_seller_id"><option value="">-- Không có parent --</option><% allSellers.forEach(opt => { if (opt.id !== s.id) { %><option value="<%= opt.id %>" <%= Number(s.parent_seller_id)===Number(opt.id) ? 'selected' : '' %>><%= opt.name %> (<%= opt.referral_code %>)</option><% }}) %></select>
            <span class="muted">Ví: <strong><%= currency(s.wallet_balance) %></strong></span>
            <button class="btn primary">Lưu</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</section>
<%- include('partials/footer') %>