<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quản lý người bán</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials-nav') %>
  <div class="container">
    <div class="grid">
      <div class="card">
        <h2>Thêm người bán</h2>
        <form action="/admin/sellers" method="POST">
          <label>Tên shop</label>
          <input name="name" required>
          <label>Email</label>
          <input name="email" type="email" required>
          <label>Hoa hồng (%)</label>
          <input name="commissionPercent" type="number" required>
          <button class="btn" type="submit">Thêm người bán</button>
        </form>
      </div>
      <div class="card">
        <h2>Danh sách người bán</h2>
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Tên</th>
              <th>Email</th>
              <th>Hoa hồng</th>
            </tr>
          </thead>
          <tbody>
            <% sellers.forEach(s => { %>
              <tr>
                <td><%= s.id %></td>
                <td><%= s.name %></td>
                <td><%= s.email %></td>
                <td><span class="badge"><%= s.commissionPercent %>%</span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>
