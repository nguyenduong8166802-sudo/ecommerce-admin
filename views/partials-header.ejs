
<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'DUONG MART PRO' %></title>
  <link rel="stylesheet" href="/public/css/style.css" />
</head>
<body>
<header class="topbar">
  <div class="brand">DUONG MART PRO</div>
  <nav class="nav">
    <a href="/">Trang chủ</a>
    <% if (currentUser && currentUser.role === 'seller') { %>
      <a href="/seller/products">Seller</a>
    <% } %>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a href="/admin/products">Admin</a>
      <a href="/seller/products">Seller view</a>
    <% } %>
    <% if (!currentUser) { %>
      <a href="/login">Đăng nhập</a>
    <% } else { %>
      <form action="/logout" method="POST"><button class="btn-ghost">Đăng xuất</button></form>
    <% } %>
  </nav>
</header>
<div class="container">
