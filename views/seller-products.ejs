
<%- include('partials/header') %>
<section class="panel-header">
  <h1>Seller quản lý sản phẩm</h1>
  <a class="btn primary" href="/seller/products/new">+ Thêm sản phẩm</a>
</section>
<table class="table">
  <thead>
    <tr>
      <th>ID</th><th>Tên</th><th>Giá</th><th>Tồn</th><th>Hiển thị</th><th>Thao tác</th>
    </tr>
  </thead>
  <tbody>
    <% products.forEach(p => { %>
      <tr>
        <td><%= p.id %></td>
        <td><%= p.name %></td>
        <td><%= Number(p.price).toLocaleString('vi-VN') %> đ</td>
        <td><%= p.stock %></td>
        <td><%= p.is_active ? 'Có' : 'Ẩn' %></td>
        <td class="actions">
          <a class="btn small" href="/seller/products/<%= p.id %>/edit">Sửa</a>
          <form action="/seller/products/<%= p.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Xóa sản phẩm này?')">
            <button class="btn danger small" type="submit">Xóa</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('partials/footer') %>
