<%- include('partials/header') %>
<section class="section">
  <div class="container narrow">
    <h1>Chính sách hoa hồng người bán</h1>
    <div class="content-box">
      <p>Marketplace trừ commission theo từng seller. Công thức:</p>
      <p><strong>Hoa hồng sàn = Giá trị đơn hàng seller x % commission</strong></p>
      <p><strong>Seller thực nhận = Giá trị đơn hàng - Hoa hồng sàn</strong></p>
    </div>
    <table class="table top-gap">
      <tr><th>Seller</th><th>Email</th><th>% hoa hồng</th><th>Thông tin đối soát</th></tr>
      <% sellers.forEach(seller => { %>
        <tr>
          <td><%= seller.fullName %></td>
          <td><%= seller.email %></td>
          <td><%= seller.commissionRate %>%</td>
          <td><%= seller.payoutInfo %></td>
        </tr>
      <% }) %>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
