<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>DUONG MART PRO</title><link rel="stylesheet" href="/public/css/style.css"></head><body>
<div class="nav"><div class="nav-inner"><div><a class="brand" href="/">DUONG MART PRO</a></div>
<div class="links">
<a href="/">Trang chủ</a>
<% if (!currentUser) { %><a href="/login">Đăng nhập</a><a href="/register">Đăng ký</a><% } %>
<% if (currentUser && currentUser.role==='seller') { %><a href="/seller/products">Seller</a><% } %>
<% if (currentUser && currentUser.role==='admin') { %><a href="/admin">Admin</a><a href="/admin/products">Quản lý sản phẩm</a><% } %>
<% if (currentUser) { %><form action="/logout" method="post" style="display:inline"><button class="btn" style="padding:8px 12px">Đăng xuất</button></form><% } %>
</div></div></div>
<div class="container">

<div class="hero">
  <div class="card">
    <div class="badge">BẢN ỔN ĐỊNH AUTO DB</div>
    <h1>TUYỂN CỘNG TÁC VIÊN BÁN HÀNG</h1>
    <p class="muted">Đăng ký seller để tự đăng sản phẩm, có link affiliate F1 và hệ thống quản lý đơn cơ bản.</p>
    <div class="row">
      <a class="btn" href="/register">Đăng ký seller</a>
      <a class="btn secondary" href="/login">Đăng nhập</a>
    </div>
  </div>
  <div class="card">
    <h3>Điểm nổi bật</h3>
    <ul class="muted">
      <li>Admin CRUD sản phẩm full</li>
      <li>Seller CRUD sản phẩm full</li>
      <li>Auto tạo bảng DB khi chạy</li>
      <li>Đăng ký buyer / seller</li>
    </ul>
  </div>
</div>

<h2>Sản phẩm nổi bật</h2>
<div class="grid">
<% products.forEach(p => { %>
  <div class="card">
    <img class="product-img" src="<%= p.image_url || 'https://via.placeholder.com/600x400?text=No+Image' %>" alt="">
    <h3><%= p.name %></h3>
    <div class="muted"><%= p.seller_name || 'Chưa có seller' %></div>
    <p><%= p.description || '' %></p>
    <strong><%= Number(p.price).toLocaleString('vi-VN') %>đ</strong>
    <div class="row" style="margin-top:10px">
      <% if (currentUser) { %>
        <form method="post" action="/buy/<%= p.id %>"><button class="btn">Mua ngay</button></form>
      <% } else { %>
        <a class="btn" href="/login">Đăng nhập để mua</a>
      <% } %>
    </div>
  </div>
<% }) %>
</div>
</div></body></html>