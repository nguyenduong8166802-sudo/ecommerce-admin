
<%- include('partials/header') %>
<section class="hero">
  <div>
    <h1>Website bán hàng chuẩn vận hành thật</h1>
    <p>Bán sản phẩm, tuyển seller, quản lý đơn và chỉnh sửa sản phẩm trực tiếp trên admin hoặc seller.</p>
    <div class="cta-row">
      <a class="btn primary" href="/register">Đăng ký tài khoản</a>
      <a class="btn" href="/seller/products">Quản lý sản phẩm</a>
    </div>
  </div>
</section>

<section>
  <h2>Sản phẩm nổi bật</h2>
  <div class="grid">
    <% products.forEach(product => { %>
      <div class="card">
        <img src="<%= product.image_url || 'https://via.placeholder.com/600x400?text=San+pham' %>" alt="<%= product.name %>" />
        <div class="card-body">
          <h3><%= product.name %></h3>
          <p class="price"><%= Number(product.price).toLocaleString('vi-VN') %> đ</p>
          <p class="muted">Seller: <%= product.seller_name || 'Chưa gán' %></p>
          <p><%= product.description || '' %></p>
          <form action="/cart/add/<%= product.id %>" method="POST">
            <button class="btn primary" type="submit">Thêm vào giỏ</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
</section>
<%- include('partials/footer') %>
