<%- include('partials/header') %>
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="badge">PRO Marketplace</span>
      <h1><%= site.heroTitle %></h1>
      <p><%= site.heroSubtitle %></p>
      <div class="hero-actions">
        <a class="btn" href="/shop">Mua sắm ngay</a>
        <a class="btn btn-outline" href="/login">Đăng nhập admin/seller</a>
      </div>
    </div>
    <div class="hero-card">
      <h3>Khung tính năng có sẵn</h3>
      <ul>
        <li>Admin dashboard</li>
        <li>Seller dashboard</li>
        <li>Quản lý sản phẩm</li>
        <li>Giỏ hàng & checkout</li>
        <li>Tự tính commission</li>
      </ul>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head between center">
      <h2>Danh mục nổi bật</h2>
      <a href="/shop">Xem tất cả</a>
    </div>
    <div class="cat-grid">
      <% categories.forEach(cat => { %>
        <a class="cat-card" href="/shop?category=<%= cat.id %>"><%= cat.name %></a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section gray">
  <div class="container">
    <div class="section-head between center">
      <h2>Flash sale</h2>
      <a href="/shop">Xem shop</a>
    </div>
    <div class="product-grid">
      <% flashSale.forEach(product => { %>
        <div class="product-card">
          <img src="<%= product.imageUrl %>" alt="<%= product.name %>" />
          <div class="product-body">
            <small><%= product.categoryName %> · <%= product.sellerName %></small>
            <h3><a href="/product/<%= product.slug %>"><%= product.name %></a></h3>
            <p><%= product.shortDesc %></p>
            <div class="price-row">
              <strong><%= currency(product.finalPrice) %></strong>
              <% if (product.salePrice) { %><span><%= currency(product.price) %></span><% } %>
            </div>
            <form action="/cart/add" method="post">
              <input type="hidden" name="productId" value="<%= product.id %>" />
              <button class="btn btn-block">Thêm vào giỏ</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head between center">
      <h2>Sản phẩm nổi bật</h2>
    </div>
    <div class="product-grid">
      <% featured.forEach(product => { %>
        <div class="product-card">
          <img src="<%= product.imageUrl %>" alt="<%= product.name %>" />
          <div class="product-body">
            <small><%= product.categoryName %> · <%= product.sellerName %></small>
            <h3><a href="/product/<%= product.slug %>"><%= product.name %></a></h3>
            <p><%= product.shortDesc %></p>
            <div class="price-row">
              <strong><%= currency(product.finalPrice) %></strong>
              <% if (product.salePrice) { %><span><%= currency(product.price) %></span><% } %>
            </div>
            <form action="/cart/add" method="post">
              <input type="hidden" name="productId" value="<%= product.id %>" />
              <button class="btn btn-block">Thêm vào giỏ</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
